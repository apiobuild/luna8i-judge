DB_DIR=./db
DATABASE_FILENAME=local.db

GEMINI_API_KEY=
DEFAULT_SOTA_MODEL=gemini/gemini-2.0-flash

# Set to true when running locally to enable file path input instead of file upload
LOCAL_MODE=false

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DASHSCOPE_API_KEY=
# Set to your vLLM server URL to enable vllm/* models and the /api/vllm model management endpoints.
# Leave unset (or blank) if not using a local GPU server.
VLLM_HOST=
# Set to your Ollama server URL to enable ollama/* models and the /api/ollama model management endpoints.
# Defaults to http://localhost:11434 when unset — no key required.
OLLAMA_HOST=

DATA_DIR=./data
